module LanguageServer
  module Protocol
    module Interface
      #
      # Registration options for a {@link CompletionRequest}.
      #
      class CompletionRegistrationOptions
        def initialize: (document_selector: untyped, ?trigger_characters: Array[String], ?all_commit_characters: Array[String], ?resolve_provider: bool, ?completion_item: untyped, ?work_done_progress: bool) -> void

        @attributes: Hash[Symbol, untyped]
        attr_reader attributes: Hash[Symbol, untyped]

        %a{pure}
        def document_selector: () -> untyped

        %a{pure}
        def trigger_characters: () -> Array[String]

        %a{pure}
        def all_commit_characters: () -> Array[String]

        %a{pure}
        def resolve_provider: () -> bool

        %a{pure}
        def completion_item: () -> untyped

        %a{pure}
        def work_done_progress: () -> bool

        def to_hash: () -> Hash[Symbol, untyped]

        def to_json: (*untyped) -> String
      end
    end
  end
end
